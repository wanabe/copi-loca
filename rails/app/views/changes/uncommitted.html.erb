<h1>Uncommitted</h1>
<p><%= link_to "Go to Amend Commit", amend_changes_path, class: "changes-link-amend" %></p>
<%= render partial: "staging_area", locals: {
      unstaged_files: @unstaged_files,
      staged_files: @staged_files,
      unstaged_file_path: @unstaged_file_path,
      staged_file_path: @staged_file_path,
      file_diff: @file_diff,
      unstaged_link: ->(path) { uncommitted_changes_path(unstaged_file_path: path) },
      staged_link: ->(path) { uncommitted_changes_path(staged_file_path: path) },
      stage_url: stage_changes_path,
      unstage_url: unstage_changes_path,
      stage_label: "Stage this change",
      unstage_label: "Unstage this change",
      stage_amend: false,
      unstage_amend: false
    } %>

<%= form_with url: commit_changes_path, method: :post, local: true do |form| %>
  <div>
    <%= form.label :commit_message, "Commit message" %><br>
    <%= form.text_area :commit_message, rows: 3, cols: 60 %>
  </div>
  <%= form.submit "Commit staged changes", class: "changes-commit-btn", disabled: @staged_files.empty? %>
<% end %>
