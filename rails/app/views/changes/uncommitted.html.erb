<h1>Uncommitted Changes</h1>
<h2>Unstaged Changes</h2>
<ul>
  <% @unstaged_files.each do |file| %>
    <% selected = (file == @unstaged_file_path) %>
    <li class="changes-list__item<%= " changes-list__item--selected" if selected %>"><a href="<%= uncommitted_changes_path(unstaged_file_path: file) %>"><%= h file %></a></li>
  <% end %>
</ul>
<h2>Staged Changes</h2>
<ul>
  <% @staged_files.each do |file| %>
    <% selected = (file == @staged_file_path) %>
    <li class="changes-list__item<%= " changes-list__item--selected" if selected %>"><a href="<%= uncommitted_changes_path(staged_file_path: file) %>"><%= h file %></a></li>
  <% end %>
</ul>
<% if @file_diff %>
  <hr>
  <% if @unstaged_file_path %>
    <%= form_with url: stage_changes_path, method: :post, local: true do |form| %>
      <%= form.hidden_field :file_path, value: @unstaged_file_path %>
      <%= form.submit "Stage this change", class: "changes-stage-btn" %>
    <% end %>
  <% end %>
  <%= render partial: "diff", locals: { file_diffs: [ @file_diff ] } %>
<% end %>
