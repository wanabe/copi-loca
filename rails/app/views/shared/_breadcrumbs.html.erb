<%# locals: (session: nil) %>
<nav aria-label="breadcrumb" class="mobile-breadcrumbs breadcrumbs-nav">
  <ol class="breadcrumb breadcrumbs-list">
    <% breadcrumbs.each do |crumb| %>
      <li class="breadcrumb-item">
        <% if crumb.link? && crumb != breadcrumbs.last %>
          <%= link_to crumb.name, crumb.path, class: "breadcrumb-link" %>
        <% else %>
          <span class="breadcrumb-page"><%= crumb.name %></span>
        <% end %>
      </li>
    <% end %>
  </ol>
  <% if session&.model.present? %>
    <span class="session-model breadcrumbs-session-model"> <%= session.model %></span>
  <% end %>
</nav>
