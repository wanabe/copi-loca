#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"

COVERAGE_FILE = File.expand_path("../coverage/.resultset.json", __dir__)
OUTPUT_FILE = File.expand_path("../docs/insufficient_coverage_report.json", __dir__)

INSUFFICIENT_THRESHOLD = 1 # lines with nil or 0 are considered insufficient

abort "Coverage file not found: #{COVERAGE_FILE}" unless File.exist?(COVERAGE_FILE)

data = JSON.parse(File.read(COVERAGE_FILE))
coverage = data.values.first["coverage"]

insufficient = []

coverage.each do |file, info|
  lines = info["lines"]
  next unless lines

  uncovered = []
  lines.each_with_index do |count, idx|
    uncovered << (idx + 1) if count&.zero?
  end
  next if uncovered.empty?

  insufficient << {
    file: file,
    uncovered_lines: uncovered
  }
end

File.open(OUTPUT_FILE, "w") do |f|
  f.puts JSON.pretty_generate(insufficient)
end

puts "Insufficient coverage report written to #{OUTPUT_FILE}"
